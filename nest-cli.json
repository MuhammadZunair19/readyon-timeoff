{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "monorepo": true,
  "root": ".",
  "sourceRoot": "apps/timeoff-service/src",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": false,
    "tsConfigPath": "tsconfig.build.json"
  },
  "projects": {
    "timeoff-service": {
      "type": "application",
      "root": "apps/timeoff-service",
      "entryFile": "main",
      "sourceRoot": "apps/timeoff-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/timeoff-service/tsconfig.app.json"
      }
    },
    "hcm-mock-server": {
      "type": "application",
      "root": "apps/hcm-mock-server",
      "entryFile": "main",
      "sourceRoot": "apps/hcm-mock-server/src",
      "compilerOptions": {
        "tsConfigPath": "apps/hcm-mock-server/tsconfig.app.json"
      }
    }
  }
}
